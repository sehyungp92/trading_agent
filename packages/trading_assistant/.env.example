# Copy to packages/trading_assistant/.env on the local workstation.
TRADING_MODE=paper

ORCHESTRATOR_API_KEY=change-me

RELAY_HOST=127.0.0.1
RELAY_PORT=8001
RELAY_API_KEY=change-me
RELAY_PURGE_DAYS=14
RELAY_SHARED_SECRETS={"swing_multi_01":"change-me","momentum_nq_01":"change-me","stock_trader":"change-me","k_stock_trader":"change-me","paper_bot_01":"change-me","crypto":"change-me"}

# Set only for local unauthenticated smoke tests. Leave empty in paper/live.
ALLOW_UNAUTHENTICATED_RELAY_DEV=
