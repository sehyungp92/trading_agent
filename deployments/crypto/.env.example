# Copy to deployments/crypto/.env on the crypto VPS and replace all secrets.
TZ=UTC

POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading_admin
POSTGRES_PASSWORD=change-me
POSTGRES_WRITER_PASSWORD=change-me
POSTGRES_READER_PASSWORD=change-me

# The mounted file should be copied from bots/crypto_trader/config/live_config.example.json
# and contain wallet, relay_url, relay_secret, bot_id, and promoted round_3 paths.
CRYPTO_LIVE_CONFIG_PATH=./secrets/live_config.json

DOWNLOAD_COINS=BTC,ETH,SOL
DOWNLOAD_INTERVALS=15m,1h,4h,1d
DOWNLOAD_DAYS=90
