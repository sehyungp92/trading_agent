# Copy to deployments/k_stock/.env on the K-stock VPS and replace all secrets.
TZ=Asia/Seoul

POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading_admin
POSTGRES_PASSWORD=change-me
POSTGRES_WRITER_PASSWORD=change-me
POSTGRES_READER_PASSWORD=change-me

OMS_HOST_PORT=8000
OMS_URL=http://oms:8000
OMS_ID=k_stock_primary
OMS_CONFIG_PATH=config/oms_config.yaml
OMS_ALLOW_MISSING_STRATEGY_BUDGETS=
OMS_ALLOW_MISSING_SECTOR_MAP=

KIS_IS_PAPER=true
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_HTS_ID=
KIS_MY_AGENT=Mozilla/5.0

RELAY_URL=http://<WORKSTATION_PRIVATE_IP>:8001
SIDECAR_RELAY_URL=http://<WORKSTATION_PRIVATE_IP>:8001
INSTRUMENTATION_HMAC_SECRET=change-me
K_STOCK_SIDECAR_BOT_ID=k_stock_trader
K_STOCK_SIDECAR_BATCH_SIZE=50
K_STOCK_SIDECAR_RETRY_MAX=5
K_STOCK_SIDECAR_RETRY_BACKOFF_SECONDS=10
K_STOCK_SIDECAR_BUFFER_DIR=instrumentation/data/.sidecar_buffer
K_STOCK_SIDECAR_POLL_SECONDS=15

OLR_KALCB_TRADE_DATE=YYYY-MM-DD
OLR_KALCB_PREFLIGHT_MODE=artifact_only_stage1
OLR_KALCB_RUNTIME_MODE=dry_run
OLR_KALCB_MARKET_DATA_SOURCE=auto
OLR_KALCB_POLL_SECONDS=15
OLR_KALCB_BARS_PARQUET=
OLR_KALCB_ONCE=0
KIS_WS_LEDGER_PATH=data/rate_budget/kis_ws_ledger.json
