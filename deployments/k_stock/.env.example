# Copy to deployments/k_stock/.env on the K-stock VPS and replace all secrets.
TZ=Asia/Seoul

POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading_admin
POSTGRES_PASSWORD=change-me
POSTGRES_WRITER_PASSWORD=change-me
POSTGRES_READER_PASSWORD=change-me

OMS_HOST_PORT=8000
OMS_URL=http://oms:8000
OMS_ID=k_stock_primary
OMS_CONFIG_PATH=config/oms_config.yaml
OMS_ALLOW_MISSING_STRATEGY_BUDGETS=
OMS_ALLOW_MISSING_SECTOR_MAP=

# Absolute path is recommended on the VPS; it must contain strategy/, live_readiness/,
# krx_daily_parquet/, kis_intraday_parquet/, oms/, and paper_live/.
K_STOCK_HOST_DATA_ROOT=/opt/trading_agent/runtime_data/k_stock

KIS_IS_PAPER=true
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_HTS_ID=
KIS_MY_AGENT=Mozilla/5.0

RELAY_URL=http://<WORKSTATION_PRIVATE_IP>:8001
SIDECAR_RELAY_URL=http://<WORKSTATION_PRIVATE_IP>:8001
INSTRUMENTATION_HMAC_SECRET=change-me
K_STOCK_SIDECAR_BOT_ID=k_stock_trader
K_STOCK_SIDECAR_BATCH_SIZE=50
K_STOCK_SIDECAR_RETRY_MAX=5
K_STOCK_SIDECAR_RETRY_BACKOFF_SECONDS=10
K_STOCK_SIDECAR_BUFFER_DIR=instrumentation/data/.sidecar_buffer
K_STOCK_SIDECAR_POLL_SECONDS=15

OLR_KALCB_TRADE_DATE=YYYY-MM-DD
# Artifact-only modes are for k-stock-preflight. The long-running trader accepts dry_run, paper, or live.
OLR_KALCB_PREFLIGHT_MODE=artifact_only_stage1
OLR_KALCB_RUNTIME_MODE=dry_run
OLR_KALCB_MARKET_DATA_SOURCE=auto
OLR_KALCB_BASELINE_MANIFEST=/app/deployments/k_stock/generated/live_readiness/olr_kalcb/baseline_manifest.json
OLR_KALCB_PORTFOLIO_POLICY=config/olr_kalcb/portfolio_policy.conservative.json
OLR_KALCB_SECTOR_MAP=config/olr/sector_map.yaml
OLR_KALCB_POLL_SECONDS=15
OLR_KALCB_BARS_PARQUET=
OLR_KALCB_KIS_WS_URL=
OLR_KALCB_WS_LEDGER_PATH=
OLR_KALCB_OUTPUT_JSON=
OLR_KALCB_DEPLOYMENT_METADATA_PATH=
OLR_KALCB_DEPLOYMENT_METADATA_ENV=paper_vps
OLR_KALCB_STRATEGY_PLUGIN_CONTRACT=contracts/strategy_plugins/k_stock_olr_kalcb/strategy_plugin_contract.json
OLR_KALCB_ONCE=0
KIS_WS_LEDGER_PATH=data/rate_budget/kis_ws_ledger.json
