.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

_[!_]*/
**/_[!_]*/

# Bot-local runtime/backtest outputs stay out of deployable package trees.
trading/*/output/
trading/*/backtests/output/
trading/*/data/backtests/output/
data/data/*.db
*.sqlite
*.sqlite3

# Local-only generated artifacts. Canonical small indexes and schemas remain tracked.
artifacts/local/
backtests/baselines/tmp/
deployments/**/generated/local/
deployments/**/generated/runtime_deployment_metadata/
artifacts/validation/runtime_deployment_metadata/raw/

# Local credentials and environment overlays.
.env
.env.*
!.env.example

.agents/
_references/
docs/
