# Copy to deployments/ibkr/.env on the IBKR VPS and replace all secrets.
TZ=America/New_York
TRADING_MODE=paper
TRADING_ENV=paper

POSTGRES_PORT=5432
DB_NAME=trading
DB_USER=trading_writer
DB_PASSWORD=change-me

TWS_USERID=
TWS_PASSWORD=
READ_ONLY_API=no
TWOFA_TIMEOUT_ACTION=exit
VNC_SERVER_PASSWORD=change-me
IB_GATEWAY_LIVE_PORT=4001
IB_GATEWAY_PAPER_PORT=4002
IB_GATEWAY_VNC_PORT=5900

IB_HOST=127.0.0.1
IB_PORT=4002
IB_ACCOUNT_ID=
ACCOUNT_ALIAS=ibkr_paper
TRADING_ACCOUNT_ALIAS=ibkr_paper

INSTRUMENTATION_RELAY_URL=http://<WORKSTATION_PRIVATE_IP>:8001
INSTRUMENTATION_HMAC_SECRET=change-me
